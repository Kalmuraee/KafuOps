{
  "name": "kafuops",
  "version": "0.3.1",
  "description": "Open-source, self-hostable AI production-debugging agent for backend teams — turns incidents into sandbox-validated, evidence-backed merge requests. Bring your own LLM (OpenAI/Anthropic/local).",
  "license": "AGPL-3.0-only",
  "author": "Khalid (https://github.com/Kalmuraee)",
  "funding": "https://github.com/Kalmuraee/KafuOps",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kafuops": "bin/kafuops.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kalmuraee/KafuOps.git"
  },
  "homepage": "https://kalmuraee.github.io/KafuOps/",
  "bugs": {
    "url": "https://github.com/Kalmuraee/KafuOps/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node bin/kafuops.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@octokit/rest": "^21.0.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "minimatch": "^10.0.1",
    "nanoid": "^5.0.9",
    "openai": "^4.77.0",
    "ora": "^8.1.1",
    "prompts": "^2.4.2",
    "simple-git": "^3.27.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "ai",
    "sre",
    "ai-sre",
    "aiops",
    "debugging",
    "debugging-agent",
    "incident-response",
    "incident-management",
    "root-cause-analysis",
    "observability",
    "devops",
    "on-call",
    "production",
    "self-hosted",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "pull-request",
    "merge-request",
    "automation",
    "cli",
    "typescript",
    "ai-agent"
  ]
}
